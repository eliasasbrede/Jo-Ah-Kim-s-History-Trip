---
import Layout from '../layouts/Layout.astro';
import HotelCard from '../components/HotelCard.astro';
import hotelData from '../data/hotels.json';

const base = '/Jo-Ah-Kim-s-History-Trip';
---

<Layout title="Hotels" description="Curated five-star properties chosen for their historical significance and luxury standards.">
  <main class="container">
    <header class="page-header">
      <h1 class="page-title">Curated Hotels</h1>
      <p class="page-subtitle">A collection of Vietnam’s most historic and prestigious addresses.</p>
    </header>

    <div class="hotels-grid">
      {hotelData.map((hotel) => (
        <HotelCard {...hotel} />
      ))}
    </div>

    <section class="hotel-philosophy section">
      <div class="card bg-accent-soft text-center p-lg">
        <h3>A Commitment to Legacy</h3>
        <p>The hotels selected for this journey are not merely places to sleep. They are living museums and monuments to craftsmanship, specifically chosen to complement the historical narrative of each city.</p>
        <p><em>Note: Final selections may be subject to availability and seasonal booking requirements.</em></p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    padding: var(--spacing-lg) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .page-title {
    font-size: 3rem;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .hotels-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .text-center {
    text-align: center;
  }

  .p-lg {
    padding: var(--spacing-lg);
  }
</style>
