---
import Layout from '../layouts/Layout.astro';
import SectionSuggestion from '../components/SectionSuggestion.astro';

const base = '/Jo-Ah-Kim-s-History-Trip';
---

<Layout title="Pricing Estimation" description="Detailed budget and cost estimation for the 7-night Vietnam history trip for five people.">
  <main class="container">
    <header class="page-header">
      <h1 class="page-title">Price Estimation</h1>
      <p class="page-subtitle">A detailed breakdown for a 5-person premium historical journey.</p>
    </header>

    <div class="pricing-summary-cards">
      <div class="card pricing-hero-card">
        <h3>Estimated Planning Total</h3>
        <div class="price-big">$18,000</div>
        <p>Recommended planning number for 5 people. This provides a sensible margin for a high-quality, embarrassment-free experience.</p>
      </div>
      
      <div class="card pricing-range-card">
        <h3 class="card-title-sm">Budget Style Tiers</h3>
        <ul class="range-list">
          <li>
            <div class="range-info">
              <span class="range-label">Sensible Luxury</span>
              <span class="range-desc">Selected Five-Star & Premium Local</span>
            </div>
            <span class="range-value">$15,500+</span>
          </li>
          <li>
            <div class="range-info">
              <span class="range-label">Realistic Premium</span>
              <span class="range-desc">Metropole / Nam Hai / Private Guide</span>
            </div>
            <span class="range-value">$18,000+</span>
          </li>
          <li>
            <div class="range-info">
              <span class="range-label">Indulgent Heritage</span>
              <span class="range-desc">Top Suites / Fine Wine / Helicopter</span>
            </div>
            <span class="range-value">$22,000+</span>
          </li>
        </ul>
      </div>
    </div>

    <section class="itinerary-pricing section">
      <h2 class="section-title">Day-by-Day Estimate</h2>
      <div class="pricing-timeline">
        <!-- Day 1 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 1 — Hanoi arrival</h4>
            <span class="day-total">Day total: ~$1,975</span>
          </div>
          <ul class="pricing-items">
            <li>Metropole Hanoi, 3 rooms: $1,650</li>
            <li>Airport transfer + light local transport: $120</li>
            <li>Short orientation guide: $80</li>
            <li>Dinner at Cha Ca Thang Long: $125</li>
          </ul>
        </div>

        <!-- Day 2 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 2 — Hanoi historical core</h4>
            <span class="day-total">Day total: ~$2,840</span>
          </div>
          <ul class="pricing-items">
            <li>Metropole Hanoi, 3 rooms: $1,650</li>
            <li>Private guide + vehicle: $250</li>
            <li>Entry tickets: $40</li>
            <li>Dinner at Gia: $800</li>
            <li>Lunch / coffee / incidentals: $100</li>
          </ul>
        </div>

        <!-- Day 3 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 3 — Trang An + Hoa Lu</h4>
            <span class="day-total">Day total: ~$2,200</span>
          </div>
          <ul class="pricing-items">
            <li>Metropole Hanoi, 3 rooms: $1,650</li>
            <li>Private vehicle + guide for full-day excursion: $300</li>
            <li>Boat / site tickets: $75</li>
            <li>Meals: $175</li>
          </ul>
        </div>

        <!-- Day 4 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 4 — Fly to Huế / birthday day</h4>
            <span class="day-total">Day total: ~$1,325</span>
          </div>
          <ul class="pricing-items">
            <li>Silk Path Grand Hue, 3 rooms: $450</li>
            <li>Hanoi → Huế flights for 5: ~$255</li>
            <li>Transfers + local guide: $180</li>
            <li>Imperial City tickets: $40</li>
            <li>Birthday dinner at hotel: $400</li>
          </ul>
        </div>

        <!-- Day 5 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 5 — Huế tombs and pagoda</h4>
            <span class="day-total">Day total: ~$930</span>
          </div>
          <ul class="pricing-items">
            <li>Silk Path Grand Hue, 3 rooms: $450</li>
            <li>Private guide + vehicle: $220</li>
            <li>Site tickets: $60</li>
            <li>Meals: $200</li>
          </ul>
        </div>

        <!-- Day 6 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 6 — Huế to Hội An via Da Nang</h4>
            <span class="day-total">Day total: ~$2,779</span>
          </div>
          <ul class="pricing-items">
            <li>Four Seasons The Nam Hai, 3 rooms: $2,199</li>
            <li>Intercity private transfer + guide: $300</li>
            <li>Cham Museum + stop costs: $30</li>
            <li>Meals: $250</li>
          </ul>
        </div>

        <!-- Day 7 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 7 — Hội An + Mỹ Sơn</h4>
            <span class="day-total">Day total: ~$3,184</span>
          </div>
          <ul class="pricing-items">
            <li>Four Seasons The Nam Hai, 3 rooms: $2,199</li>
            <li>Private guide + vehicle: $300</li>
            <li>Site tickets: $60</li>
            <li>Lunch + dinner: $625 (assumes a refined Nen Danang experience)</li>
          </ul>
        </div>

        <!-- Day 8 -->
        <div class="pricing-day-card card">
          <div class="pricing-day-header">
            <h4>Day 8 — Ho Chi Minh City day + airport handoff</h4>
            <span class="day-total">Day total: ~$765</span>
          </div>
          <ul class="pricing-items">
            <li>Da Nang → Ho Chi Minh City flights for 5: ~$270</li>
            <li>Private city vehicle + guide: $220</li>
            <li>Museum / palace tickets: $25</li>
            <li>Meals + transfers: $250</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="pricing-add-ons section">
      <div class="grid">
        <div class="card">
          <h3>Potential Add-ons</h3>
          <ul class="check-list">
            <li><strong>HCMC Extension:</strong> Caravelle Saigon (3 rooms) + Dinner/Buffer: ~$775</li>
            <li><strong>Upgrades:</strong> Premium villa categories at Nam Hai</li>
            <li><strong>Aero:</strong> Business class on regional flights</li>
            <li><strong>Dining:</strong> Extensive wine pairings</li>
          </ul>
        </div>
        
        <div class="card bg-accent-soft">
          <h3>The Planning Buffer</h3>
          <p>The <strong>$18,000 target</strong> includes a 10–15% contingency for:</p>
          <ul class="check-list">
            <li>Fare and room-category changes</li>
            <li>Guide overtime & transfer adjustments</li>
            <li>Incidentals, snacks, and coffees</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="pricing-footer section text-center">
      <div class="card p-lg">
        <h3>Core 7-night Vietnam Trip</h3>
        <div class="price-medium">Estimated Total: ~$16,000</div>
        <p class="muted">Excluding contingency and HCMC overnights.</p>
        <p class="mt-md italic">“This happens fast if we choose higher categories or more indulgent options, but $18,000 remains the stable middle ground for a professional planning target.”</p>
      </div>
    </section>

    <SectionSuggestion section="pricing" title="Budget & Style Suggestions" />
  </main>
</Layout>

<style>
  .page-header {
    padding: var(--spacing-lg) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .pricing-summary-cards {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .pricing-hero-card {
    background-color: var(--color-primary);
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: var(--spacing-lg);
  }

  .pricing-hero-card h3 { color: var(--color-accent-soft); }

  .price-big {
    font-family: var(--font-serif);
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: var(--spacing-sm) 0;
  }

  .price-medium {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0.5rem 0;
  }

  .range-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .range-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-bg-alt);
    padding: 0.75rem 0;
  }

  .range-info {
    display: flex;
    flex-direction: column;
  }

  .range-label { font-weight: 700; font-size: 0.9rem; color: var(--color-primary); }
  .range-desc { font-size: 0.75rem; color: var(--color-text-muted); }
  .range-value { font-family: var(--font-serif); font-weight: 700; color: var(--color-accent); font-size: 1.1rem; }

  .card-title-sm {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .pricing-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .pricing-day-card {
    padding: var(--spacing-md);
  }

  .pricing-day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .day-total {
    font-weight: 700;
    color: var(--color-accent);
    font-family: var(--font-serif);
  }

  .pricing-items {
    list-style: none;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .pricing-items li::before {
    content: '—';
    margin-right: 0.5rem;
    color: var(--color-accent);
  }

  .check-list {
    list-style: none;
    margin-top: 1rem;
  }

  .check-list li::before {
    content: '✓';
    color: var(--color-accent);
    margin-right: 0.75rem;
    font-weight: bold;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  .bg-accent-soft { background-color: var(--color-accent-soft); }
  .text-center { text-align: center; }
  .p-lg { padding: var(--spacing-lg); }
  .mt-md { margin-top: var(--spacing-md); }
  .italic { font-style: italic; }
  .muted { font-size: 0.85rem; color: var(--color-text-muted); }

  @media (max-width: 900px) {
    .pricing-summary-cards, .grid {
      grid-template-columns: 1fr;
    }
    
    .price-big { font-size: 3rem; }
  }
</style>
