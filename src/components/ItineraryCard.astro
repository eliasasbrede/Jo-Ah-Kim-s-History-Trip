---
interface Dining {
  lunch: string;
  dinner: string;
  note: string;
}

interface Props {
  day: number;
  date: string;
  title: string;
  location: string;
  description: string;
  activities: string[];
  dining: Dining;
  accommodation: string;
  historyNote: string;
}

const { day, date, title, location, description, activities, dining, accommodation, historyNote } = Astro.props;

// Format date to local friendly string
const dateObj = new Date(date);
const dateStr = dateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
---

<div class="itinerary-card card">
  <div class="card-header">
    <div class="day-badge badge badge-gold">Day {day}</div>
    <div class="date-text" aria-label="Scheduled Date">{dateStr}</div>
  </div>
  
  <div class="card-body">
    <div class="card-main">
      <h3 class="day-title">{title}</h3>
      <p class="location-tag" aria-label="City Location">{location}</p>
      
      <p class="day-description">{description}</p>
      
      <div class="activities-section" aria-labelledby={`activities-day-${day}`}>
        <h4 id={`activities-day-${day}`}>Key Activities</h4>
        <ul>
          {activities.map((activity) => (
            <li>{activity}</li>
          ))}
        </ul>
      </div>
      
      <div class="history-insight">
        <p><strong>Historical Insight:</strong> {historyNote}</p>
      </div>
    </div>
    
    <div class="card-meta" role="complementary" aria-label="Dining and Accommodation">
      <div class="dining-box" id={`dining-day-${day}`}>
        <h4>Dining Notes</h4>
        <p><strong>Lunch:</strong> {dining.lunch}</p>
        <p><strong>Dinner:</strong> {dining.dinner}</p>
        <p class="dining-note">{dining.note}</p>
      </div>
      
      <div class="accommodation-box" id={`acc-day-${day}`}>
        <h4>Accommodation</h4>
        <p>{accommodation}</p>
      </div>
    </div>
  </div>
</div>

<style>
  .itinerary-card {
    margin-bottom: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    background-color: white;
    transition: var(--transition);
  }

  .itinerary-card:hover {
    box-shadow: var(--shadow-hover);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-sm);
  }

  .date-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
    font-family: var(--font-sans);
  }

  .card-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-lg);
  }

  .day-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  .location-tag {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--spacing-md);
    display: inline-block;
  }

  .day-description {
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
  }

  .activities-section h4, .dining-box h4, .accommodation-box h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-weight: 700;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--color-accent-soft);
    display: inline-block;
  }

  .activities-section ul {
    list-style-type: none;
    padding: 0;
    color: var(--color-text);
  }

  .activities-section li {
    margin-bottom: 0.6rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.95rem;
  }

  .activities-section li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .history-insight {
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md);
    background-color: var(--color-bg-alt);
    border-left: 4px solid var(--color-accent);
    font-size: 0.92rem;
    line-height: 1.6;
    border-radius: 0 4px 4px 0;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    padding-left: var(--spacing-lg);
    border-left: 1px solid var(--color-border);
  }

  .dining-box p, .accommodation-box p {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .dining-note {
    font-size: 0.85rem !important;
    color: var(--color-text-muted);
    margin-top: 0.75rem !important;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--color-border);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .card-body {
      grid-template-columns: 1fr;
    }
    
    .card-meta {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-top: var(--spacing-lg);
    }
    
    .day-title {
      font-size: 1.75rem;
    }
  }

  @media print {
    .itinerary-card {
      page-break-inside: avoid;
      box-shadow: none;
      border: 1px solid #eee;
      margin-bottom: 3rem;
    }
    .card-header, .location-tag {
      color: black !important;
    }
  }
</style>
