---
interface Props {
  name: string;
  city: string;
  reason: string;
  location: string;
  image: string;
  url: string;
}

const { name, city, reason, location, image, url } = Astro.props;
---

<div class="hotel-card card">
  <div class="hotel-image">
    <img src={image} alt={`Exterior or interior of ${name}`} loading="lazy" />
  </div>
  
  <div class="hotel-info">
    <div class="hotel-header">
      <h3 class="hotel-name">{name}</h3>
      <span class="hotel-city badge badge-gold">{city}</span>
    </div>
    
    <p class="hotel-location"><strong>Location:</strong> {location}</p>
    
    <p class="hotel-reason">
      <em>{reason}</em>
    </p>
    
    <div class="hotel-footer">
      <a href={url} target="_blank" rel="noopener noreferrer" class="btn btn-outline small" aria-label={`Visit official website for ${name}`}>View Website</a>
    </div>
  </div>
</div>

<style>
  .hotel-card {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: var(--spacing-md);
    padding: 0;
    overflow: hidden;
    margin-bottom: var(--spacing-md);
    background-color: white;
    transition: var(--transition);
  }

  .hotel-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .hotel-image {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .hotel-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .hotel-card:hover .hotel-image img {
    transform: scale(1.05);
  }

  .hotel-info {
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  .hotel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .hotel-name {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    color: var(--color-primary);
  }

  .hotel-location {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .hotel-reason {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .hotel-footer {
    margin-top: var(--spacing-sm);
  }

  .small {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .hotel-card {
      grid-template-columns: 1fr;
    }
    
    .hotel-image {
      height: 250px;
    }
  }
</style>
