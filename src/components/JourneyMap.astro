---
import routeData from '../data/route.json';

interface Props {
  height?: string;
  zoom?: number;
  interactive?: boolean;
}

const { height = "400px", zoom = 5, interactive = true } = Astro.props;
---

<div class="map-container no-print" style={`height: ${height};`}>
  <div id="map" class="journey-map"></div>
  <div class="map-overlay">
    <span>The Historical Arc: Hanoi to Saigon</span>
  </div>
</div>

<!-- Load Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

<style>
  .map-container {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin: var(--spacing-md) 0;
    box-shadow: var(--shadow-sm);
  }

  .journey-map {
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .map-overlay {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: rgba(255, 255, 255, 0.9);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    z-index: 1000;
    pointer-events: none;
    border: 1px solid var(--color-border);
  }

  /* Make the map tiles look more premium/muted */
  :global(.leaflet-tile-pane) {
    filter: grayscale(100%) contrast(0.8) brightness(1.1) sepia(0.2);
  }

  :global(.leaflet-container) {
    background: #f8f9fa;
    font-family: var(--font-sans);
  }
</style>

<script is:inline define:vars={{ routeData, zoom, interactive }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Check if map element exists
    const mapElement = document.getElementById('map');
    if (!mapElement) return;

    // Load Leaflet JS dynamically if not already loaded
    if (typeof L === 'undefined') {
      const script = document.createElement('script');
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.integrity = "sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=";
      script.crossOrigin = "";
      script.onload = initMap;
      document.head.appendChild(script);
    } else {
      initMap();
    }

    function initMap() {
      // Center on the middle of the route
      const map = L.map('map', {
        scrollWheelZoom: false,
        dragging: interactive,
        zoomControl: interactive
      }).setView([16.0, 107.5], zoom);

      // Muted, clean tile layer (Voyager / CartoDB)
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);

      // Customized Icon
      const stopIcon = L.divIcon({
        className: 'custom-div-icon',
        html: "<div style='background-color: #c5a059; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 5px rgba(0,0,0,0.3);'></div>",
        iconSize: [12, 12],
        iconAnchor: [6, 6]
      });

      // Prepare markers and path
      const latlngs = [];
      routeData.forEach(stop => {
        const marker = L.marker(stop.coordinates, { icon: stopIcon }).addTo(map);
        marker.bindPopup(`<strong>${stop.name}</strong><br/>${stop.description}`);
        latlngs.push(stop.coordinates);
      });

      // Draw the connecting route
      const polyline = L.polyline(latlngs, {
        color: '#c5a059',
        weight: 3,
        opacity: 0.6,
        dashArray: '5, 10'
      }).addTo(map);

      // Fit bounds to the route
      map.fitBounds(polyline.getBounds(), { padding: [30, 30] });
    }
  });
</script>
