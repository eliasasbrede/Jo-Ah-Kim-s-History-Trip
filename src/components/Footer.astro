---
const currentYear = new Date().getFullYear();
const base = '/Jo-Ah-Kim-s-History-Trip';
---

<footer class="footer no-print">
  <div class="container footer-content">
    <div class="footer-brand">
      <h3 class="footer-title">Joachim’s 70th Birthday Journey</h3>
      <p class="footer-subtitle">A Historical Vietnam Week</p>
      <p class="footer-text">May 23 – 30, 2026</p>
    </div>
    
    <div class="footer-links">
      <ul class="footer-nav">
        <li><a href={`${base}/`}>Home</a></li>
        <li><a href={`${base}/itinerary`}>Itinerary</a></li>
        <li><a href={`${base}/hotels`}>Hotels</a></li>
        <li><a href={`${base}/history`}>History Themes</a></li>
        <li><a href={`${base}/practicalities`}>Practicalities</a></li>
      </ul>
    </div>
    
    <div class="footer-info">
      <p class="copyright">© {currentYear} — A Family Birthday Gift</p>
      <p class="footer-note">Handcrafted for Joachim’s milestone celebration.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: white;
    padding: var(--spacing-lg) 0;
    margin-top: var(--spacing-xl);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    align-items: start;
  }

  .footer-title {
    color: white;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .footer-subtitle {
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-text {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-nav a:hover {
    color: white;
  }

  .footer-info {
    text-align: right;
  }

  .copyright {
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .footer-note {
    font-size: 0.8rem;
    opacity: 0.6;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--spacing-md);
    }
    
    .footer-info {
      text-align: center;
    }
  }
</style>
