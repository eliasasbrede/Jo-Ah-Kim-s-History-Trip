---
const links = [
  { href: "/", label: "Home" },
  { href: "/itinerary", label: "Itinerary" },
  { href: "/hotels", label: "Hotels" },
  { href: "/dining", label: "Dining" },
  { href: "/history", label: "History Themes" },
  { href: "/pricing", label: "Pricing" },
];

const base = '/Jo-Ah-Kim-s-History-Trip';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  const fullPath = `${base}${path === '/' ? '' : path}`;
  // Handle both trailing slash and no trailing slash
  return currentPath === fullPath || currentPath === `${fullPath}/`;
};
---

<nav class="nav no-print">
  <div class="container nav-content">
    <a href={`${base}/`} class="logo">
      <span class="logo-text">Historical Vietnam Week</span>
      <span class="logo-sub">Joachim’s 70th Birthday</span>
    </a>
    
    <button class="mobile-menu-toggle" id="mobile-toggle" aria-label="Toggle Menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    
    <ul class="nav-links" id="nav-links">
      {links.map((link) => (
        <li>
          <a 
            href={`${base}${link.href}`} 
            class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
  
  <div class="mobile-overlay" id="mobile-overlay">
    <ul class="mobile-links">
      {links.map((link) => (
        <li>
          <a 
            href={`${base}${link.href}`} 
            class={`mobile-link ${isActive(link.href) ? 'active' : ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const overlay = document.getElementById('mobile-overlay');
  const body = document.body;

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    toggle.classList.toggle('open');
    overlay?.classList.toggle('open');
    body.classList.toggle('menu-open');
  });

  // Close menu on link click
  const mobileLinks = document.querySelectorAll('.mobile-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      toggle?.classList.remove('open');
      overlay?.classList.remove('open');
      body.classList.remove('menu-open');
    });
  });
</script>

<style>
  .nav {
    border-bottom: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 2000;
    padding: 0.75rem 0;
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    flex-direction: column;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-family: var(--font-serif);
    transition: opacity 0.3s ease;
  }

  .logo:hover {
    opacity: 0.8;
  }

  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .logo-sub {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: -1px;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nav-link {
    color: var(--color-text-muted);
    padding: 0.5rem 0;
    position: relative;
    transition: var(--transition);
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 2px;
    background-color: var(--color-accent);
    transition: var(--transition);
  }

  .nav-link:hover::after, .nav-link.active::after {
    width: 100%;
  }

  /* Mobile Toggle */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 3000;
    padding: 0;
  }

  .bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transition: var(--transition);
    transform-origin: left center;
  }

  .mobile-menu-toggle.open .bar:nth-child(1) {
    transform: rotate(45deg);
  }
  .mobile-menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle.open .bar:nth-child(3) {
    transform: rotate(-45deg);
  }

  /* Mobile Overlay */
  .mobile-overlay {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100vh;
    background-color: white;
    z-index: 2500;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: right 0.4s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .mobile-overlay.open {
    right: 0;
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-link {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    transition: var(--transition);
  }

  .mobile-link.active {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>
