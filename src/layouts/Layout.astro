---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "A curated seven-night historical journey through Vietnam: from the dynastic capital of Hanoi to the imperial grandeur of Huế and the modern pulse of Saigon. A 70th birthday gift for Joachim.",
  image = "https://images.unsplash.com/photo-1526761122248-c31c93f8b2b9?auto=format&fit=crop&q=80&w=1200"
} = Astro.props;

const base = '/Jo-Ah-Kim-s-History-Trip';
const siteTitle = "Historical Vietnam Week";
const fullTitle = title === "Home" ? `${siteTitle} | Joachim’s 70th Birthday` : `${title} | ${siteTitle}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    
    <!-- OpenGraph meta tags -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Historical Vietnam Week" />
    
    <!-- Twitter meta tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Prefetch for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Accessibility: No-JS fallback -->
    <noscript>
      <style>
        .animate-fade-up, .animate-fade-up-delay, .animate-fade-up-delay-2 {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <Navigation />
    <slot />
    <Footer />
  </body>
</html>
